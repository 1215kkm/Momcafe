# Supabase — 프로젝트 생성 후 Settings > API에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
# 서버 전용 (외부 노출 절대 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# secret-ad 외부 SEO API (Q9 부분 수정으로 외부 호출)
# 비밀 무기 레포의 api 서버를 띄운 뒤 입력. 비워두면 SEO 기능은 OFF (Graceful Degradation)
SECRET_AD_API_URL=http://localhost:3001
SECRET_AD_API_KEY=
